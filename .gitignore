# Django media files (user uploads - keep structure but ignore content)
media/uploads/*
!media/uploads/.gitkeep
media/*.jpg
media/*.jpeg
media/*.png
media/*.gif
media/*.pdf

# Django static files (if collected)
staticfiles/
static_root/

